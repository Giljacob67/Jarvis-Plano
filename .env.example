OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_ALLOWED_USER_ID=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
GOOGLE_OAUTH_SCOPES=https://www.googleapis.com/auth/calendar.events https://www.googleapis.com/auth/tasks
GOOGLE_GMAIL_ENABLED=true
GOOGLE_GMAIL_SCOPES=https://www.googleapis.com/auth/gmail.readonly https://www.googleapis.com/auth/gmail.compose
GMAIL_INBOX_QUERY_DEFAULT=in:inbox newer_than:7d
GMAIL_MAX_LIST_RESULTS=10
GOOGLE_ENCRYPTION_KEY=

OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
OPENAI_TTS_MODEL=gpt-4o-mini-tts
VOICE_RESPONSES_ENABLED=false
VOICE_RESPONSE_VOICE=alloy
MAX_AUDIO_FILE_MB=19
TEMP_AUDIO_DIR=/tmp/jarvis_audio

JARVIS_DATABASE_URL=sqlite:///./jarvis.db
APP_ENV=development
TIMEZONE=America/Sao_Paulo
APP_BASE_URL=

# ── Proactive Automations & Approvals (Phase 6) ───────────────────────────────
PROACTIVE_FEATURES_ENABLED=true

# Morning briefing — sent once per day at the configured time
MORNING_BRIEFING_ENABLED=true
MORNING_BRIEFING_TIME=08:00

# Evening review — sent once per day at the configured time
EVENING_REVIEW_ENABLED=true
EVENING_REVIEW_TIME=18:30

# Scheduler interval (minutes) — how often to check for reminders/routines
REMINDER_CHECK_INTERVAL_MINUTES=10
DEFAULT_TIMEZONE=America/Sao_Paulo

# Approval center
APPROVALS_ENABLED=true
MAX_PENDING_APPROVALS=20
FOLLOWUP_DEFAULT_DAYS=2

# Quiet hours — no proactive messages sent during this window
QUIET_HOURS_ENABLED=true
QUIET_HOURS_START=22:00
QUIET_HOURS_END=07:00

# Minimum interval between proactive messages of the same type (minutes)
PROACTIVE_MIN_INTERVAL_MINUTES=30

# ── Browser Automation (Phase 7) ─────────────────────────────────────────────
#
# BROWSER_AUTOMATION_ENABLED — master switch (default true, but all navigation
#   is still blocked unless BROWSER_ALLOWED_DOMAINS is explicitly set).
BROWSER_AUTOMATION_ENABLED=false

# BROWSER_ALLOWED_DOMAINS — comma-separated list of domains Jarvis may visit.
#   IMPORTANT: empty string = ALL navigation blocked, even with automation enabled.
#   There is no open-access fallback.
#
#   Examples:
#     BROWSER_ALLOWED_DOMAINS=example.com,docs.python.org
#     BROWSER_ALLOWED_DOMAINS=meuportal.com.br,app.notion.so,github.com
#
BROWSER_ALLOWED_DOMAINS=

BROWSER_HEADLESS=true
BROWSER_DEFAULT_TIMEOUT_MS=15000
BROWSER_NAVIGATION_TIMEOUT_MS=30000
BROWSER_SESSION_TTL_MINUTES=20
BROWSER_DOWNLOAD_DIR=/tmp/jarvis_downloads
BROWSER_SCREENSHOT_DIR=/tmp/jarvis_screens
BROWSER_MAX_STEPS_PER_RUN=25
BROWSER_REQUIRE_APPROVAL_FOR_SUBMIT=true
BROWSER_ALLOW_FILE_DOWNLOADS=true
